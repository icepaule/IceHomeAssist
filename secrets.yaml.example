# Home Assistant Secrets
# ACHTUNG: Diese Datei nach secrets.yaml kopieren und Platzhalter ausfüllen!
# cp secrets.yaml.example secrets.yaml

# Home
home_name: "Zuhause"
home_latitude: "YOUR_LATITUDE"
home_longitude: "YOUR_LONGITUDE"
home_elevation: "YOUR_ELEVATION"
home_timezone: "Europe/Berlin"
internal_url: "http://YOUR_HA_IP:8123"
external_url: "http://YOUR_HA_IP:8123"

# MQTT (Mosquitto Addon)
mqtt_host: "core-mosquitto"
mqtt_port: "1883"
mqtt_username: "YOUR_MQTT_USERNAME"
mqtt_password: "YOUR_MQTT_PASSWORD"

# Telegram (optional)
telegram_bot_token: "YOUR_TELEGRAM_BOT_TOKEN"
telegram_chat_id: "YOUR_TELEGRAM_CHAT_ID"

# Pushover (optional)
pushover_api_token: "YOUR_PUSHOVER_API_TOKEN"
pushover_user_key: "YOUR_PUSHOVER_USER_KEY"

# Divera 24/7
divera_api_key: "YOUR_DIVERA_API_KEY"

# Tibber API
tibber_access_token: "YOUR_TIBBER_ACCESS_TOKEN"
tibber_access_token_bearer: "Bearer YOUR_TIBBER_ACCESS_TOKEN"
