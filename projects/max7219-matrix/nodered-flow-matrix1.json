    "id": "m1_store_yesterday",
    "type": "function",
    "z": "tab_matrix1",
    "name": "Speichere Vortag",
    "func": "var attrs = msg.attributes;\nif (attrs && attrs.new_state && attrs.new_state.attributes) {\n    var lp = parseFloat(attrs.new_state.attributes.last_period);\n    if (!isNaN(lp)) {\n        flow.set('m1_yesterday_kwh', lp);\n    }\n}",
