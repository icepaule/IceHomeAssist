custom_components/

# Run lock
.ha_run.lock

# Cloud config
.cloud/

# HA Version file
.HA_VERSION

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# www generated files (radar SVGs, etc.)
www/

